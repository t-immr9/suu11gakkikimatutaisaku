<script>
const LB=['ア','イ','ウ','エ'];
const LVS=[
  {lv:1,n:'見習い🧙',e:0,s:'加減算の呪文'},
  {lv:2,n:'初級術士⚡',e:80,s:'不等式の結界'},
  {lv:3,n:'数の探究者🔍',e:180,s:'集合探知術'},
  {lv:4,n:'命題の騎士🛡',e:300,s:'真偽判定の剣'},
  {lv:5,n:'魔法学士⚗',e:440,s:'証明魔法の書'},
  {lv:6,n:'論理の賢人📜',e:600,s:'対偶変換術'},
  {lv:7,n:'数理の達人🌟',e:780,s:'無理数の盾'},
  {lv:8,n:'古の魔道士🔮',e:980,s:'必要十分の法'},
  {lv:9,n:'伝承の継承者👁',e:1200,s:'全知全能の目'},
  {lv:10,n:'伝説の賢者👑',e:1440,s:'数学の究極奥義'},
];

// 問題データ。LaTeX式は通常の文字列として格納（\\ でエスケープ）
const AQ=[
  {q:'\\(a<b\\) のとき、\\(a+4\\) と \\(b+4\\) の大小関係は？',c:['\\(a+4<b+4\\)','\\(a+4>b+4\\)','\\(a+4=b+4\\)','大小は決まらない'],a:0,e:'両辺に同じ数を加えても不等号の向きは変わらない。\\(a+4<b+4\\)'},
  {q:'\\(a<b\\) のとき、\\(-2a\\) と \\(-2b\\) の大小関係は？',c:['\\(-2a<-2b\\)','\\(-2a>-2b\\)','\\(-2a=-2b\\)','大小は決まらない'],a:1,e:'負の数をかけると不等号の向きが逆になる。\\(-2a>-2b\\)'},
  {q:'\\(a<b\\) のとき、\\(\\dfrac{a}{4}\\) と \\(\\dfrac{b}{4}\\) の大小関係は？',c:['\\(\\dfrac{a}{4}<\\dfrac{b}{4}\\)','\\(\\dfrac{a}{4}>\\dfrac{b}{4}\\)','\\(\\dfrac{a}{4}=\\dfrac{b}{4}\\)','大小は決まらない'],a:0,e:'正の数をかけるので向きは変わらない。\\(\\dfrac{a}{4}<\\dfrac{b}{4}\\)'},
  {q:'\\(a<b\\) のとき、\\(-\\dfrac{a}{3}\\) と \\(-\\dfrac{b}{3}\\) の大小関係は？',c:['\\(-\\dfrac{a}{3}>-\\dfrac{b}{3}\\)','\\(-\\dfrac{a}{3}<-\\dfrac{b}{3}\\)','\\(-\\dfrac{a}{3}=-\\dfrac{b}{3}\\)','大小は決まらない'],a:0,e:'負の数をかけると向きが逆になる。\\(-\\dfrac{a}{3}>-\\dfrac{b}{3}\\)'},
  {q:'1次不等式 \\(x-2<3\\) を解け。',c:['\\(x<5\\)','\\(x>5\\)','\\(x<1\\)','\\(x>1\\)'],a:0,e:'\\(x<3+2=5\\)'},
  {q:'1次不等式 \\(2x\\geq 8\\) を解け。',c:['\\(x\\geq 4\\)','\\(x\\leq 4\\)','\\(x\\geq 16\\)','\\(x\\leq 2\\)'],a:0,e:'両辺を2で割ると \\(x\\geq 4\\)'},
  {q:'1次不等式 \\(-7x\\geq 21\\) を解け。',c:['\\(x\\leq -3\\)','\\(x\\geq -3\\)','\\(x\\leq 3\\)','\\(x\\geq 3\\)'],a:0,e:'両辺を \\(-7\\) で割る（負なので向き逆）。\\(x\\leq -3\\)'},
  {q:'1次不等式 \\(8x-7<9\\) を解け。',c:['\\(x<2\\)','\\(x<-2\\)','\\(x>2\\)','\\(x>-2\\)'],a:0,e:'\\(8x<16\\) より \\(x<2\\)'},
  {q:'1次不等式 \\(7+2x<5x-6\\) を解け。',c:['\\(x>\\dfrac{13}{3}\\)','\\(x<\\dfrac{13}{3}\\)','\\(x>-1\\)','\\(x<-1\\)'],a:0,e:'\\(-3x<-13\\) より \\(x>\\dfrac{13}{3}\\)'},
  {q:'1次不等式 \\(3(2x+1)>x-2\\) を解け。',c:['\\(x>-1\\)','\\(x<-1\\)','\\(x>1\\)','\\(x<1\\)'],a:0,e:'\\(6x+3>x-2\\) より \\(5x>-5\\)、\\(x>-1\\)'},
  {q:'1次不等式 \\(\\dfrac{2}{3}x-\\dfrac{1}{6}\\geq\\dfrac{1}{4}x-1\\) を解け。',c:['\\(x\\geq -2\\)','\\(x\\leq -2\\)','\\(x\\geq 2\\)','\\(x\\leq 2\\)'],a:0,e:'両辺×12：\\(8x-2\\geq 3x-12\\) より \\(5x\\geq -10\\)、\\(x\\geq -2\\)'},
  {q:'1次不等式 \\(0.2x-1\\geq 0.4x-1.5\\) を解け。',c:['\\(x\\leq\\dfrac{5}{2}\\)','\\(x\\geq\\dfrac{5}{2}\\)','\\(x\\leq -\\dfrac{5}{2}\\)','\\(x\\geq -\\dfrac{5}{2}\\)'],a:0,e:'両辺×10：\\(2x-10\\geq 4x-15\\) より \\(-2x\\geq -5\\)、\\(x\\leq\\dfrac{5}{2}\\)'},
  {q:'連立不等式 \\(\\begin{cases}3x+8\\geq 4x-3\\\\3(2x+1)>x-2\\end{cases}\\) を解け。',c:['\\(-1<x\\leq 11\\)','\\(x\\leq 11\\)','\\(x>-1\\)','解なし'],a:0,e:'第1式：\\(x\\leq 11\\)、第2式：\\(x>-1\\)。共通は \\(-1<x\\leq 11\\)'},
  {q:'不等式 \\(-8\\leq 3x-5\\leq 4\\) を解け。',c:['\\(-1\\leq x\\leq 3\\)','\\(-3\\leq x\\leq 1\\)','\\(1\\leq x\\leq 3\\)','\\(-1<x<3\\)'],a:0,e:'各辺+5：\\(-3\\leq 3x\\leq 9\\)、÷3：\\(-1\\leq x\\leq 3\\)'},
  {q:'ケーキ1個140円、シュークリーム1個100円、合わせて20個で2500円以下。ケーキは最大何個か？',c:['12個','10個','15個','8個'],a:0,e:'\\(140x+100(20-x)\\leq 2500\\) より \\(40x\\leq 500\\)、\\(x\\leq 12.5\\)。最大12個。'},
  {q:'\\(\\dfrac{1}{\\sqrt{6}}\\) の分母を有理化せよ。',c:['\\(\\dfrac{\\sqrt{6}}{6}\\)','\\(\\dfrac{1}{6}\\)','\\(\\dfrac{\\sqrt{6}}{3}\\)','\\(\\sqrt{6}\\)'],a:0,e:'分母・分子に \\(\\sqrt{6}\\) をかけて \\(\\dfrac{\\sqrt{6}}{6}\\)'},
  {q:'\\(\\dfrac{\\sqrt{2}}{\\sqrt{3}-\\sqrt{2}}\\) の分母を有理化せよ。',c:['\\(\\sqrt{6}+2\\)','\\(\\sqrt{6}-2\\)','\\(2\\sqrt{3}-\\sqrt{2}\\)','\\(\\sqrt{6}\\)'],a:0,e:'分母・分子に \\((\\sqrt{3}+\\sqrt{2})\\) をかけると \\(\\dfrac{\\sqrt{2}(\\sqrt{3}+\\sqrt{2})}{1}=\\sqrt{6}+2\\)'},
  {q:'\\(A=\\{1,2,4,8,16\\},\\; B=\\{2,4,6,8,10\\}\\) のとき \\(A\\cap B\\) は？',c:['\\(\\{2,4,8\\}\\)','\\(\\{1,6,10,16\\}\\)','\\(\\{1,2,4,6,8,10,16\\}\\)','\\(\\emptyset\\)'],a:0,e:'両方に含まれる要素：\\(\\{2,4,8\\}\\)'},
  {q:'\\(A=\\{1,2,4,8,16\\},\\; B=\\{2,4,6,8,10\\}\\) のとき \\(A\\cup B\\) は？',c:['\\(\\{1,2,4,6,8,10,16\\}\\)','\\(\\{2,4,8\\}\\)','\\(\\{1,6,10,16\\}\\)','\\(\\{6,10\\}\\)'],a:0,e:'どちらかに含まれる要素全体：\\(\\{1,2,4,6,8,10,16\\}\\)'},
  {q:'\\(A=\\{2,3,6\\}\\)、\\(B\\) を18の正の約数全体とする。2集合の関係は？',c:['\\(A\\subset B\\)','\\(B\\subset A\\)','\\(A=B\\)','関係なし'],a:0,e:'18の約数：\\(\\{1,2,3,6,9,18\\}\\)。\\(A\\) の全要素が \\(B\\) に含まれるので \\(A\\subset B\\)'},
  {q:'\\(A=\\{1,3,5,15\\}\\)、\\(B\\) を15の正の約数全体とする。2集合の関係は？',c:['\\(A=B\\)','\\(A\\subset B\\)','\\(B\\subset A\\)','関係なし'],a:0,e:'15の約数：\\(\\{1,3,5,15\\}\\)。\\(A\\) と一致するので \\(A=B\\)'},
  {q:'\\(U=\\{1,2,\\ldots,9\\}\\)、\\(A=\\{1,2,4,7,8,9\\}\\) のとき \\(\\overline{A}\\) は？',c:['\\(\\{3,5,6\\}\\)','\\(\\{1,2,4,7,8,9\\}\\)','\\(\\{1,3,5,6,9\\}\\)','\\(\\emptyset\\)'],a:0,e:'\\(U\\) から \\(A\\) を除いた集合：\\(\\{3,5,6\\}\\)'},
  {q:'\\(U=\\{1,\\ldots,9\\},\\; A=\\{1,2,4,7,8,9\\},\\; B=\\{1,4,6,7,9\\}\\) のとき \\(A\\cap\\overline{B}\\) は？',c:['\\(\\{2,8\\}\\)','\\(\\{1,4,7,9\\}\\)','\\(\\{2,3,5,8\\}\\)','\\(\\{3,5,6\\}\\)'],a:0,e:'\\(\\overline{B}=\\{2,3,5,6,8\\}\\)。\\(A\\cap\\overline{B}=\\{2,8\\}\\)'},
  {q:'命題「4の倍数は偶数である」の真偽は？',c:['真','偽','判断できない','条件による'],a:0,e:'\\(4n=2(2n)\\) より偶数。真。'},
  {q:'命題「正三角形は二等辺三角形である」の真偽は？',c:['真','偽','判断できない','条件による'],a:0,e:'正三角形は3辺相等で特に2辺以上等しい。真。'},
  {q:'「\\(n\\) は5の倍数 \\(\\Rightarrow\\) \\(n\\) は10の倍数」の逆は？',c:['\\(n\\) は10の倍数 \\(\\Rightarrow\\) \\(n\\) は5の倍数','5の倍数でない \\(\\Rightarrow\\) 10の倍数でない','10の倍数でない \\(\\Rightarrow\\) 5の倍数でない','5の倍数でない \\(\\Rightarrow\\) 10の倍数'],a:0,e:'「\\(p\\Rightarrow q\\)」の逆は「\\(q\\Rightarrow p\\)」'},
  {q:'「\\(x=5\\Rightarrow x^2=25\\)」の逆は？',c:['\\(x^2=25\\Rightarrow x=5\\)','\\(x\\neq 5\\Rightarrow x^2\\neq 25\\)','\\(x^2\\neq 25\\Rightarrow x\\neq 5\\)','\\(x^2=25\\Rightarrow x\\neq 5\\)'],a:0,e:'逆は仮定と結論を入れ替える。\\(x^2=25\\Rightarrow x=5\\)（この逆は偽、\\(x=-5\\) の反例あり）'},
  {q:'「\\(x^2=16\\) は \\(x=-4\\) であるための（　）条件」は？',c:['必要条件','十分条件','必要十分条件','条件にならない'],a:0,e:'\\(x=-4\\Rightarrow x^2=16\\) は真（十分）。逆は偽（\\(x=4\\) も可）。よって \\(x^2=16\\) は \\(x=-4\\) の必要条件。'},
  {q:'「\\(x=0\\) は \\(xy=0\\) であるための（　）条件」は？',c:['十分条件','必要条件','必要十分条件','条件にならない'],a:0,e:'\\(x=0\\Rightarrow xy=0\\) は真（十分）。逆は偽（\\(y=0\\) でも成立）。よって十分条件のみ。'},
  {q:'「\\(3x=3y\\) は \\(x=y\\) であるための（　）条件」は？',c:['必要十分条件','十分条件のみ','必要条件のみ','条件にならない'],a:0,e:'\\(3x=3y\\Leftrightarrow x=y\\) は同値。必要十分条件。'},
  {q:'「\\(x=1\\) かつ \\(y=1\\)」の否定は？',c:['\\(x\\neq 1\\) または \\(y\\neq 1\\)','\\(x\\neq 1\\) かつ \\(y\\neq 1\\)','\\(x=1\\) または \\(y=1\\)','\\(x\\neq 1\\) かつ \\(y=1\\)'],a:0,e:'「かつ」の否定は「または」。各条件も否定。\\(x\\neq 1\\) または \\(y\\neq 1\\)'},
  {q:'「\\(x,y\\) はともに正」の否定は？',c:['\\(x,y\\) の少なくとも一方は0以下','\\(x,y\\) はともに0以下','少なくとも一方は正','\\(x,y\\) はともに負'],a:0,e:'「ともに」の否定は「少なくとも一方は」。正の否定は0以下。'},
