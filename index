// ---- ユーティリティ ----
function fy(a){const r=[...a];for(let i=r.length-1;i>0;i--){const j=Math.floor(Math.random()*(i+1));[r[i],r[j]]=[r[j],r[i]];}return r;}
function buildSets(){const s=fy(AQ.map((_,i)=>i));const n=s.length;return[s.slice(0,Math.ceil(n/3)),s.slice(Math.ceil(n/3),Math.ceil(n/3)*2),s.slice(Math.ceil(n/3)*2)];}
function getLv(e){let c=LVS[0];for(const l of LVS)if(e>=l.e)c=l;return c;}

// 画面切替：確実にsGameを見せるためにflag管理
const SCREENS=['sTitle','sGame','sLvUp','sResult'];
function showScreen(id){SCREENS.forEach(x=>{const el=document.getElementById(x);if(x===id)el.classList.remove('hidden');else el.classList.add('hidden');});}

// MathJax組版：ロード待ち＋clearMath＋typeset
function mj(el, cb){
  function run(){
    if(window.MathJax&&typeof MathJax.typesetPromise==='function'){
      // 既存の組版をクリアしてから再組版
      MathJax.typesetClear([el]);
      MathJax.typesetPromise([el]).then(()=>{if(cb)cb();}).catch(e=>console.warn(e));
    }else{
      setTimeout(run,80);
    }
  }
  run();
}

// ---- ゲーム状態 ----
let SI=0,sets=[],total=0,qs=[],cur=0,hp=100,ep=0,sc=0,ok=0,dd=[];

function updStat(){
  document.getElementById('hpV').textContent=hp;
  const hb=document.getElementById('hpBar');
  hb.style.width=hp+'%';
  hb.style.background=hp>60?'linear-gradient(90deg,#22c55e,#16a34a)':hp>30?'linear-gradient(90deg,#fbbf24,#d97706)':'linear-gradient(90deg,#ef4444,#dc2626)';
  const cl=getLv(ep),nl=LVS.find(l=>l.e>ep)||LVS[LVS.length-1];
  const pct=nl.e>cl.e?(ep-cl.e)/(nl.e-cl.e)*100:100;
  document.getElementById('expBar').style.width=Math.min(pct,100)+'%';
  document.getElementById('lvBadge').textContent='Lv'+cl.lv+' '+cl.n;
  document.getElementById('scDisp').textContent=sc;
  document.getElementById('rdDisp').textContent='第'+(SI+1)+'周/全3周';
}
function updDots(){
  const dc=document.getElementById('dots');dc.innerHTML='';
  for(let i=0;i<total;i++){const d=document.createElement('div');d.className='dot';
    if(i<dd.length)d.classList.add(dd[i]?'c':'w');else if(i===cur)d.classList.add('cur');
    dc.appendChild(d);}
}
function pop(txt,color){
  const p=document.createElement('div');p.className='pop';p.style.color=color;
  p.style.left='50%';p.style.top='30%';p.style.transform='translateX(-50%)';p.textContent=txt;
  document.getElementById('app').appendChild(p);setTimeout(()=>p.remove(),1300);
}

function startGame(){SI=0;sets=buildSets();showScreen('sGame');newGame();}
function newGame(){
  hp=100;ep=0;sc=0;ok=0;dd=[];
  const idx=sets[SI];total=idx.length;
  qs=idx.map(i=>({...AQ[i],sh:fy([...Array(AQ[i].c.length).keys()]).map(k=>({t:AQ[i].c[k],o:k}))}));
  cur=0;updStat();showQ();
}

function showQ(){
  showScreen('sGame');  // レベルアップ後にも確実にゲーム画面へ
  updDots();
  const q=qs[cur];
  document.getElementById('qn').textContent='Q '+(cur+1)+' / '+total+'　（第'+(SI+1)+'周）';

  // ---- 問題文をテキストノードとしてセット（innerHTML不使用） ----
  const qtEl=document.getElementById('qt');
  qtEl.textContent=q.q;  // textContentで設定 → MathJaxがテキストを走査して組版

  document.getElementById('expl').classList.add('hidden');
  document.getElementById('nb').classList.add('hidden');

  // 選択肢
  const cg=document.getElementById('cg');cg.innerHTML='';
  q.sh.forEach((c,i)=>{
    const btn=document.createElement('button');btn.className='cb';
    const lbl=document.createElement('span');lbl.className='cl';lbl.textContent=LB[i];
    const txt=document.createElement('span');
    txt.textContent=c.t;  // textContentで設定
    btn.appendChild(lbl);btn.appendChild(txt);
    btn.onclick=()=>answer(c.o,q.a,btn);
    cg.appendChild(btn);
  });

  document.getElementById('card').classList.remove('fw');
  mj(document.getElementById('card'));  // カード全体を組版
  window.scrollTo(0,0);
}

function answer(chosen,correct,btn){
  document.getElementById('cg').querySelectorAll('.cb').forEach(b=>b.disabled=true);
  const q=qs[cur];const isOk=chosen===correct;
  document.getElementById('cg').querySelectorAll('.cb').forEach((b,i)=>{
    if(q.sh[i].o===correct)b.classList.add('ok');
    else if(b===btn&&!isOk)b.classList.add('ng');
  });

  // 解説
  const ex=document.getElementById('expl');
  ex.className='ex '+(isOk?'ok':'ng');
  // ヘッダーテキスト
  const hdr=document.createElement('div');
  hdr.textContent=isOk?'✅ 正解！':'❌ 不正解';
  // 解説テキスト（textContentで）
  const body=document.createElement('div');
  body.className='exb';
  body.textContent=q.e;
  ex.innerHTML='';ex.appendChild(hdr);ex.appendChild(body);
  ex.classList.remove('hidden');
  document.getElementById('nb').classList.remove('hidden');

  const oe=ep;
  if(isOk){sc+=100;ok++;ep+=40;dd.push(true);pop('+40 EXP','#a78bfa');
    const ol=getLv(oe).lv,nl2=getLv(ep).lv;
    if(nl2>ol){
      const ld=getLv(ep);
      document.getElementById('lut').textContent='Lv'+ld.lv+' に昇格！';
      document.getElementById('lub').textContent=ld.n;
      document.getElementById('lusk').textContent='新スキル：「'+ld.s+'」を習得！';
      showScreen('sLvUp');
    }
  }else{hp=Math.max(0,hp-10);dd.push(false);pop('-10 HP','#ef4444');document.getElementById('card').classList.add('fw');}
  updStat();
  mj(ex);
}

function dismissLv(){showScreen('sGame');}  // sGameに戻る（nextQは不要、画面復帰のみ）

function nextQ(){cur++;if(cur>=total){showResult();return;}showQ();}

function showResult(){
  showScreen('sResult');
  document.getElementById('rbadge').textContent='第'+(SI+1)+'周 / 全3周（'+total+'問セット）';
  const pct=Math.round(ok/total*100);
  let rk='';
  if(SI===2){document.getElementById('rtitle').textContent='全3周コンプリート！';rk='🎉 全問に触れました！「伝説の賢者」に近づいている！';}
  else{document.getElementById('rtitle').textContent=pct+'% 正解';
    rk=pct>=90?'🏆 完璧！「賢者の証明」を獲得':pct>=70?'⚡ 優秀！「上級術士」の実力あり':pct>=50?'📘 合格圏！もう一歩で上位へ':'🔄 要復習。知識を積み重ねよ';}
  document.getElementById('rrank').textContent=rk;
  document.getElementById('rs1').textContent=ok+'/'+total;
  document.getElementById('rs2').textContent='Lv'+getLv(ep).lv;
  document.getElementById('rs3').textContent=ep;
  const rb=document.getElementById('rBtn');
  rb.textContent=SI===0?'第2周へ進む（残り2周）▶':SI===1?'第3周へ進む（残り1周）▶':'最初から全部やり直す 🔄';
}
function onResult(){if(SI<2){SI++;newGame();}else{SI=0;sets=buildSets();newGame();}}
</script>
